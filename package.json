{
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.39.7",
    "express": "^4.18.3",
    "react": "^19",
    "react-dom": "^19",
    "unplugin-fonts": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "gh-pages": "^6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5.8",
    "ultracite": "^7.6.0",
    "vite": "^8",
    "vitest": "^3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "ultracite fix"
    ]
  },
  "name": "minesweeper",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc && vite build",
    "lint": "ultracite fix .",
    "lint:ci": "ultracite check .",
    "deploy:pages": "gh-pages -d dist",
    "deploy": "bun run build && bun run deploy:pages",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "type": "module",
  "version": "0.1.1",
  "private": true,
  "homepage": "https://lucas98sf.github.io/react-minesweeper",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
